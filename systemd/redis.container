[Unit]
Description=Redis

[Container]
ContainerName=redis
Exec=docker-entrypoint.sh --appendonly no --protected-mode no --save ""
Image=reg.mini.dev/redis:8.8.0
HealthCmd=redis-cli --raw incr ping
HealthLogDestination=events_logger
Network=backend.network
PodmanArgs=--cpus=1 --memory=128m

[Service]
Restart=always

[Install]
WantedBy=multi-user.target default.target
