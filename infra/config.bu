variant: fcos
version: 1.7.0

passwd:
  users:
    - name: core
      password_hash: "$6$/bsPz.igJ3EslNvt$v62vEJkEaINcdUAbXp3PFB4RmPHX2jDwL1PLegTiJAC8G3Kl7tIOcsJMh.nEyZPHTGk1vrGMVfRo3zKreUUsb."
      ssh_authorized_keys:
        - >-
          ssh-rsa  desktop
        - ssh-rsa  phone
        - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAILLQ7xJbWDGtI5zDJHFRBWWhJiqVFP7uLhHQ9sUL5AlF homeassistant

storage:
  trees:
    - local: filesystem
  files:
    - path: /var/lib/systemd/linger/core
      mode: 0644
  links:
    - path: /etc/systemd/user/default.target.wants/quadlet-sync.timer
      target: /etc/systemd/user/quadlet-sync.timer

