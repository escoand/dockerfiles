variant: fcos
version: 1.7.0

passwd:
  users:
    - name: core
      ssh_authorized_keys:
        - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINXVNVaVLWnPfyWK1oehq7/K9ppXKgPsRB5lZWp+fJI6 desktop
        - ssh-rsa  phone
        - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAILLQ7xJbWDGtI5zDJHFRBWWhJiqVFP7uLhHQ9sUL5AlF homeassistant

storage:
  filesystems:
    - device: /dev/disk/by-label/data
      format: ext4
      path: /var/mnt/data
      with_mount_unit: true
  directories:
    - path: /var/mnt/data
      mode: 0770
      user:
        name: core
      group:
        name: core
  trees:
    - local: filesystem
  links:
    - path: /etc/localtime
      target: /usr/share/zoneinfo/Europe/Berlin
    # enable services
    - path: /etc/systemd/system/sockets.target.wants/fail2ban-fw.socket
      target: /etc/systemd/system/fail2ban-fw.socket
    - path: /etc/systemd/user/default.target.wants/quadlet-sync.timer
      target: /etc/systemd/user/quadlet-sync.timer
    # podman auto update
    - path: /etc/systemd/user/timers.target.wants/podman-auto-update.timer
      target: /usr/lib/systemd/user/podman-auto-update.timer
