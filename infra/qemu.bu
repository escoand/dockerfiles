variant: fcos
version: 1.7.0

ignition:
  config:
    merge:
      - local: build/config.ign

passwd:
  users:
    - name: core
      password_hash: "$6$/bsPz.igJ3EslNvt$v62vEJkEaINcdUAbXp3PFB4RmPHX2jDwL1PLegTiJAC8G3Kl7tIOcsJMh.nEyZPHTGk1vrGMVfRo3zKreUUsb."
      ssh_authorized_keys:
        - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINXVNVaVLWnPfyWK1oehq7/K9ppXKgPsRB5lZWp+fJI6 desktop
        - ssh-rsa  work

storage:
  filesystems:
    - device: /dev/vdb
      format: ext4
      label: data
  files:
    - path: /etc/containers/registries.conf.d/qemu.conf
      contents:
        inline: |-
          [[registry]]
          prefix = "docker.io"
          location = "10.0.2.2:5000"
          insecure = true
          [[registry]]
          prefix = "ghcr.io"
          location = "10.0.2.2:5000"
          insecure = true
          [[registry]]
          prefix = "quay.io"
          location = "10.0.2.2:5000"
          insecure = true
          [[registry]]
          prefix = "dock.mau.dev"
          location = "10.0.2.2:5000"
          insecure = true
          [[registry]]
          prefix = "reg.mini.dev"
          location = "10.0.2.2:5000"
          insecure = true
