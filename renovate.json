{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "group:allNonMajor",
    ":separateMajorReleases"
  ],
  "baseBranches": ["master", "coreos"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "**/*.container"
      ],
      "matchStrings": [
        "Image=(docker\\.io/(library/)?)?(?<registry>\\S*/)(?<depName>\\S+):(?<currentValue>\\S+)"
      ],
      "packageNameTemplate": "{{{registry}}}{{{depName}}}",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
