[Unit]
Description=Postfix
After=network-online.target
Wants=network-online.target

[Container]
AddCapability=NET_BIND_SERVICE
ContainerName=postfix
EnvironmentFile=/var/mnt/data/%N.env
Image=docker.io/boky/postfix:v5.1.0-alpine
PublishPort=25:25
Volume=opendkim:/etc/opendkim/keys
Volume=/var/mnt/data/postfix:/etc/postfix

[Install]
WantedBy=default.target
